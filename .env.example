DATABASE_URL="postgresql://vopley:yourpassword@postgres:5432/vopley"
POSTGRES_USER="vopley"
POSTGRES_PASSWORD="yourpassword"
POSTGRES_DB="vopley"
SESSION_SECRET="session-secret"
NODE_ENV="dev"
RESEND_API_KEY="re_key"
ANNOUNCEMENTS_SECRET="your-secret-key-here"

# AdminJS admin panel credentials
# Generate password hash: node -e "import('bcryptjs').then(b=>b.default.hash('YOUR_PASSWORD',12).then(console.log))"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="$2a$12$..."
ADMIN_COOKIE_SECRET="at-least-32-chars-random-string-here"

# HTTP basic auth for /admin routes (nginx layer)
# Generate .htpasswd file: htpasswd -c .htpasswd admin_username
# Or without htpasswd: docker run --rm httpd:alpine htpasswd -nbB admin_username YOUR_PASSWORD > .htpasswd

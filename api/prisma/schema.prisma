generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String @id @default(uuid())
  username      String @unique
  password_hash String
  avatar        String
  email         String? @unique
  is_banned     Int    @default(0)
  show_nsfw     Int    @default(0)
  show_politics Int    @default(0)
  created_at    String @default(dbgenerated("(datetime('now'))"))

  shouts                Shout[]
  media                 Media[]
  shoutLikes            ShoutLike[]
  comments              Comment[]
  commentLikes          CommentLike[]
  receivedNotifications Notification[] @relation("ReceivedNotifications")
  sentNotifications     Notification[] @relation("SentNotifications")
  ignoredByMe           IgnoredUser[]  @relation("IgnoredByUser")
  ignoredByOthers       IgnoredUser[]  @relation("IgnoredTarget")
  socials               Social[]

  @@map("users")
}

model Shout {
  id         String  @id @default(uuid())
  user_id    String
  parent_id  String?
  content    String
  media_id   String?
  is_deleted      Int     @default(0)
  is_pinned       Int     @default(0)
  visibility_tag  String  @default("")
  created_at String  @default(dbgenerated("(datetime('now'))"))

  // Legacy inline media columns — retained for baseline, remove in follow-up migration
  media_type String?
  media_url  String?
  media_meta String?

  user          User           @relation(fields: [user_id], references: [id])
  parent        Shout?         @relation("ShoutReplies", fields: [parent_id], references: [id])
  children      Shout[]        @relation("ShoutReplies")
  media         Media?         @relation(fields: [media_id], references: [id])
  likes         ShoutLike[]
  comments      Comment[]
  notifications Notification[]
  poll          Poll?

  @@index([parent_id, created_at], name: "idx_shouts_parent_created")
  @@index([created_at], name: "idx_shouts_created")
  @@map("shouts")
}

model Media {
  id         String  @id @default(uuid())
  user_id    String
  media_type String
  media_url  String
  media_meta String?
  created_at String  @default(dbgenerated("(datetime('now'))"))

  user     User      @relation(fields: [user_id], references: [id])
  shouts   Shout[]
  comments Comment[]

  @@map("media")
}

model ShoutLike {
  shout_id   String
  user_id    String
  created_at String @default(dbgenerated("(datetime('now'))"))

  shout Shout @relation(fields: [shout_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([shout_id, user_id])
  @@index([shout_id], name: "idx_likes_shout")
  @@index([user_id], name: "idx_likes_user")
  @@map("shout_likes")
}

model Comment {
  id         String  @id @default(uuid())
  shout_id   String
  user_id    String
  content    String
  media_id   String?
  is_deleted Int     @default(0)
  created_at String  @default(dbgenerated("(datetime('now'))"))

  shout         Shout          @relation(fields: [shout_id], references: [id])
  user          User           @relation(fields: [user_id], references: [id])
  media         Media?         @relation(fields: [media_id], references: [id])
  likes         CommentLike[]
  notifications Notification[]

  @@index([shout_id, created_at], name: "idx_comments_shout_created")
  @@index([user_id], name: "idx_comments_user")
  @@map("comments")
}

model CommentLike {
  comment_id String
  user_id    String
  created_at String @default(dbgenerated("(datetime('now'))"))

  comment Comment @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([comment_id, user_id])
  @@index([comment_id], name: "idx_comment_likes_comment")
  @@index([user_id], name: "idx_comment_likes_user")
  @@map("comment_likes")
}

model Announcement {
  id         String @id @default(uuid())
  content    String
  is_deleted Int    @default(0)
  created_at String @default(dbgenerated("(datetime('now'))"))

  @@index([is_deleted, created_at], name: "idx_announcements_active")
  @@map("announcements")
}

model VerificationCode {
  id         String  @id @default(uuid())
  email      String
  code       String
  purpose    String
  payload    String?
  expires_at String
  used       Int     @default(0)
  attempts   Int     @default(0)
  created_at String  @default(dbgenerated("(datetime('now'))"))

  @@index([email, purpose, used], name: "idx_verification_codes_email_purpose")
  @@map("verification_codes")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model IgnoredUser {
  id             String @id @default(uuid())
  owner_user_id  String
  target_user_id String
  created_at     String @default(dbgenerated("(datetime('now'))"))
  updated_at     String @default(dbgenerated("(datetime('now'))"))

  owner  User @relation("IgnoredByUser", fields: [owner_user_id], references: [id], onDelete: Cascade)
  target User @relation("IgnoredTarget", fields: [target_user_id], references: [id], onDelete: Cascade)

  @@unique([owner_user_id, target_user_id])
  @@map("ignored_users")
}

model Poll {
  id       String @id @default(uuid())
  shout_id String @unique
  multi    Int    @default(0) // 0 = single-select, 1 = multi-select

  shout   Shout        @relation(fields: [shout_id], references: [id], onDelete: Cascade)
  options PollOption[]

  @@map("polls")
}

model PollOption {
  id      String @id @default(uuid())
  poll_id String
  text    String
  votes   Int    @default(0)

  poll      Poll       @relation(fields: [poll_id], references: [id], onDelete: Cascade)
  pollVotes PollVote[]

  @@index([poll_id], name: "idx_poll_options_poll")
  @@map("poll_options")
}

model PollVote {
  id        String @id @default(uuid())
  option_id String
  user_id   String
  created_at String @default(dbgenerated("(datetime('now'))"))

  option PollOption @relation(fields: [option_id], references: [id], onDelete: Cascade)

  @@unique([option_id, user_id])
  @@index([user_id], name: "idx_poll_votes_user")
  @@map("poll_votes")
}

model Social {
  id         String @id @default(uuid())
  user_id    String
  type       String
  url        String
  display    String @default("")
  created_at String @default(dbgenerated("(datetime('now'))"))
  updated_at String @default(dbgenerated("(datetime('now'))"))

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, type])
  @@index([user_id], name: "idx_socials_user")
  @@map("socials")
}

model Notification {
  id         String  @id @default(uuid())
  user_id    String  // target user (receives the notification)
  actor_id   String  // who triggered it
  type       String  // 'mention'; future: 'shout_like', 'comment_like'
  shout_id   String?
  comment_id String?
  is_read    Int     @default(0)
  created_at String  @default(dbgenerated("(datetime('now'))"))

  user    User     @relation("ReceivedNotifications", fields: [user_id],    references: [id], onDelete: Cascade)
  actor   User     @relation("SentNotifications",     fields: [actor_id],   references: [id], onDelete: Cascade)
  shout   Shout?   @relation(fields: [shout_id],   references: [id], onDelete: SetNull)
  comment Comment? @relation(fields: [comment_id], references: [id], onDelete: SetNull)

  @@index([user_id, is_read, created_at], name: "idx_notifications_user_unread")
  @@map("notifications")
}
